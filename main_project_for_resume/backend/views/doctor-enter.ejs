<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Login</title>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body{
            min-height: 100vh;
            background: linear-gradient(135deg,#e0f7fa,#f8fbff);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .login-container{
            width: 100%;
            max-width: 450px;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        .login-container h1{
            text-align: center;
            margin-bottom: 30px;
            color: #0f766e;
        }

        .form-group{
            display: flex;
            flex-direction: column;
            margin-bottom: 20px;
        }

        label{
            margin-bottom: 8px;
            font-weight: bold;
            color: #334155;
        }

        input{
            padding: 12px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            outline: none;
            font-size: 15px;
        }

        input:focus{
            border-color: #0f766e;
            box-shadow: 0 0 0 3px rgba(15,118,110,0.15);
        }

        button{
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 12px;
            background: #0f766e;
            color: white;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
        }

        button:hover{
            background: #115e59;
        }

        .error{
            background: #fee2e2;
            color: #991b1b;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
        }

        .register-link{
            margin-top: 20px;
            text-align: center;
        }

        .register-link a{
            color: #0f766e;
            font-weight: bold;
            text-decoration: none;
        }

    </style>

</head>
<body>

    <div class="login-container">

        <h1>Doctor Login</h1>

        <% if (typeof error !== "undefined" && error) { %>

            <div class="error">
                <%= error %>
            </div>

        <% } %>

        <form action="/doctor/enter" method="POST">

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required>
            </div>

            <button type="submit">
                Login
            </button>

        </form>

        <div class="register-link">
            New Doctor ?
            <a href="/doctor/register">Register Here</a>
        </div>

    </div>

</body>
</html>