<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <%- include('partials/bootstrap_style') %>

    <style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 20px;
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a, #312e81, #581c87);
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Arial, sans-serif;
    }

    .card-container {
        width: 100%;
        max-width: 420px;
        background: rgba(255, 255, 255, 0.95);
        padding: 35px;
        border-radius: 22px;
        box-shadow: 0 25px 55px rgba(0, 0, 0, 0.35);
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
        font-size: 30px;
        font-weight: 800;
        color: #312e81;
    }

    .error-box {
        background: #fee2e2;
        color: #991b1b;
        text-align: center;
        margin-bottom: 18px;
        font-weight: 600;
        padding: 12px;
        border-radius: 12px;
    }

    form {
        width: 100%;
    }

    input {
        width: 100%;
        padding: 13px 15px;
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        outline: none;
        margin-bottom: 15px;
        font-size: 15px;
    }

    input:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.18);
    }

    label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 6px;
    }

    button,
    .btn {
        width: 100%;
        margin-top: 10px;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
    }

    button:hover,
    .btn:hover {
        background: linear-gradient(135deg, #4338ca, #6d28d9);
        color: white;
    }

    a {
        color: #6d28d9;
        font-weight: 700;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }
</style>
</head>

<body>

    <div class="card-container">

        <% if (error && error.length > 0) { %>
            <div class="error-box">
                <%= error[0] %>
            </div>
        <% } %>

        <h2>Enter</h2>

        <%- include('partials/form_enter') %>

    </div>

    <%- include('partials/bootstap_script') %>

</body>
</html>