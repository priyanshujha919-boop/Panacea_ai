<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Home</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body{
            min-height: 100vh;
            background: linear-gradient(135deg,#e0f7fa,#f8fbff);
            color: #334155;
        }

        .navbar{
            background: #0f766e;
            color: white;
            padding: 18px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h2{
            font-size: 24px;
        }

        .navbar a{
            color: white;
            text-decoration: none;
            background: #115e59;
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: bold;
        }

        .container{
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 25px;
        }

        .welcome-card{
            background: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

        .welcome-card h1{
            color: #0f766e;
            margin-bottom: 12px;
        }

        .stats{
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card{
            background: white;
            padding: 25px;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            text-align: center;
        }

        .stat-card h2{
            color: #0f766e;
            margin-bottom: 8px;
        }

        .actions{
            display: grid;
            grid-template-columns: repeat(2,1fr);
            gap: 20px;
        }

        .action-card{
            background: white;
            padding: 25px;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

        .action-card h3{
            color: #0f766e;
            margin-bottom: 10px;
        }

        .action-card p{
            margin-bottom: 15px;
            line-height: 1.5;
        }

        .action-card a{
            display: inline-block;
            background: #0f766e;
            color: white;
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-weight: bold;
        }

        .action-card a:hover{
            background: #115e59;
        }

        @media(max-width: 750px){
            .stats,
            .actions{
                grid-template-columns: 1fr;
            }

            .navbar{
                padding: 16px 20px;
            }
        }
    </style>
</head>

<body>

    <div class="navbar">
        <h2>Doctor Dashboard</h2>
        <a href="/doctor/logout">Logout</a>
    </div>

    <div class="container">

        <div class="welcome-card">
            <h1>Welcome, Doctor</h1>
            <p>Manage your appointments, profile, availability, and patient requests from here.</p>
        </div>

        <div class="stats">
            <div class="stat-card">
                <h2>0</h2>
                <p>Today Appointments</p>
            </div>

            <div class="stat-card">
                <h2>0</h2>
                <p>Pending Requests</p>
            </div>

            <div class="stat-card">
                <h2>0</h2>
                <p>Total Patients</p>
            </div>
        </div>

        <div class="actions">
            <div class="action-card">
                <h3>My Appointments</h3>
                <p>View upcoming patient appointments and manage consultation schedule.</p>
                <a href="#">View Appointments</a>
            </div>

            <div class="action-card">
                <h3>Edit Profile</h3>
                <p>Update specialization, qualification, fee, hospital, and availability details.</p>
                <a href="#">Edit Profile</a>
            </div>

            <div class="action-card">
                <h3>Availability</h3>
                <p>Set your available days and timing for patient bookings.</p>
                <a href="#">Manage Time</a>
            </div>

            <div class="action-card">
                <h3>Patient Requests</h3>
                <p>Accept, reject, or review consultation requests from patients.</p>
                <a href="#">View Requests</a>
            </div>
        </div>

    </div>

</body>
</html>