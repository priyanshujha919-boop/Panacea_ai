<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Home</title>

    <%- include('partials/bootstrap_style') %>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body{
            min-height: 100vh;
            background: linear-gradient(135deg,#0f172a,#1e1b4b,#3b0764);
            color: white;
        }

        .navbar{
            width: 100%;
            padding: 20px 40px;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(10px);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

        .navbar h2{
            font-size: 28px;
            font-weight: bold;
            color: #f8fafc;
        }

        .navbar a{
            text-decoration: none;
            background: linear-gradient(135deg,#7c3aed,#4f46e5);
            color: white;
            padding: 10px 18px;
            border-radius: 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .navbar a:hover{
            transform: translateY(-2px);
        }

        .main-container{
            width: 100%;
            min-height: 100vh;
            padding: 120px 40px 40px;
        }

        .hero-section{
            text-align: center;
            margin-bottom: 50px;
        }

        .hero-section h1{
            font-size: 55px;
            margin-bottom: 15px;
            background: linear-gradient(to right,#ffffff,#c4b5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-section p{
            font-size: 18px;
            color: #cbd5e1;
        }

        .dashboard-grid{
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
            gap: 25px;
        }

        .dashboard-card{
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(12px);
            padding: 30px;
            border-radius: 22px;
            transition: 0.3s;
            box-shadow: 0 15px 35px rgba(0,0,0,0.25);
        }

        .dashboard-card:hover{
            transform: translateY(-8px);
        }

        .dashboard-card h3{
            margin-bottom: 15px;
            font-size: 24px;
            color: #ddd6fe;
        }

        .dashboard-card p{
            color: #cbd5e1;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .dashboard-card a{
            text-decoration: none;
            display: inline-block;
            background: linear-gradient(135deg,#7c3aed,#4f46e5);
            padding: 10px 18px;
            border-radius: 10px;
            color: white;
            font-weight: bold;
        }

        .dashboard-card a:hover{
            opacity: 0.9;
        }

        @media(max-width:768px){

            .navbar{
                padding: 15px 20px;
            }

            .hero-section h1{
                font-size: 38px;
            }

            .main-container{
                padding: 110px 20px 30px;
            }
        }

    </style>

</head>

<body>

    <div class="navbar">

        <h2>Patient Dashboard</h2>

        <a href="/user/logout">
            Logout
        </a>

    </div>

    <div class="main-container">

        <div class="hero-section">

            <h1>Welcome Patient</h1>

            <p>
                Book appointments, explore doctors and manage your health easily.
            </p>

        </div>

        <div class="dashboard-grid">

            <div class="dashboard-card">

                <h3>Find Doctors</h3>

                <p>
                    Search doctors by specialization, hospital and location.
                </p>

                <a href="#">
                    Explore
                </a>

            </div>

            <div class="dashboard-card">

                <h3>Book Appointment</h3>

                <p>
                    Schedule appointments with top doctors instantly.
                </p>

                <a href="#">
                    Book Now
                </a>

            </div>

            <div class="dashboard-card">

                <h3>My Appointments</h3>

                <p>
                    Check upcoming and previous consultations.
                </p>

                <a href="#">
                    View
                </a>

            </div>

            <div class="dashboard-card">

                <h3>Medical Records</h3>

                <p>
                    Access prescriptions, reports and treatment history.
                </p>

                <a href="#">
                    Open
                </a>

            </div>

        </div>

    </div>

    <%- include('partials/bootstap_script') %>

</body>
</html>